{
  "manifest_version": 3,
  "name": "ezclip Design Context",
  "version": "0.1.0",
  "description": "Captures active-tab fonts, colors, CSS tokens, and button styles for ezclip screenshots.",
  "key": "",
  "permissions": ["activeTab", "nativeMessaging", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Send design context to ezclip"
  }
}
