{
  "manifest_version": 3,
  "name": "ezclip",
  "version": "1.0",
  "description": "Extract design tokens and send to the ezclip macOS app",
  "browser_specific_settings": {
    "gecko": {
      "id": "ezclip@namaankohli.local",
      "strict_min_version": "110.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost:19843/*"
  ],
  "permissions": [
    "alarms",
    "activeTab"
  ]
}
